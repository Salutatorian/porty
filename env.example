# Copy this file to .env.local and paste your values:
#   cp env.example .env.local   (or copy/paste the file and rename)
# Then replace the placeholders below with:
#   - Client ID and Client Secret from https://www.strava.com/settings/api
#   - Refresh Token (from your app's Details after authorizing)
# Do not commit .env.local (it is in .gitignore).

# Admin — for adding projects and photos at /admin
ADMIN_PASSWORD=your_admin_password_here
# Local dev: after editing .env.local, restart `npm run dev` (server reads env only at startup).
# Production: set ADMIN_PASSWORD in Vercel → Project → Settings → Environment Variables, then redeploy.

# --- Cloudflare R2 (recommended) — if all are set, the app uses R2 instead of Vercel Blob.
# See ADMIN-SETUP.md for CORS and token creation.
# Migrate Blob → R2 (same keys, rewrites URLs in .json): npm run migrate:blob-to-r2:dry then npm run migrate:blob-to-r2
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=greater-engine-assets
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# Optional — if chunked uploads fail with “denied writing a staging chunk”, your token may be path-limited.
# Set to a folder your token can write (no trailing slash required), e.g. gallery/polaroids/.chunks
# R2_STAGING_PREFIX=gallery/_staging

# --- Vercel Blob (fallback if R2_* not fully set)
# For local dev: run `vercel env pull` or copy from Vercel dashboard → Storage → your Blob store.
BLOB_READ_WRITE_TOKEN=

# Optional Blob — public index URLs to skip list() on reads (Blob quota savings).
# BLOB_PHOTOS_INDEX_URL=https://....public.blob.vercel-storage.com/gallery/index.json
# BLOB_VIDEOS_INDEX_URL=https://....public.blob.vercel-storage.com/media/videos/index.json
# BLOB_PROJECTS_INDEX_URL=https://....public.blob.vercel-storage.com/projects/index.json
# BLOB_WRITINGS_INDEX_URL=https://....public.blob.vercel-storage.com/writings/index.json
# Optional Blob direct URL for /api/settings (site meta JSON). Omit to use list(prefix site/).
# BLOB_SITE_SETTINGS_URL=

# Homepage “Current / Future” projects (GET/POST/PUT/PATCH/DELETE /api/home-projects) — same pattern as other index JSONs.
# BLOB_HOME_PROJECTS_INDEX_URL=https://....public.blob.vercel-storage.com/home-projects/index.json

# Goodreads (optional) — books page at /books uses your user ID. Defaults to 199403748 if not set.
# GOODREADS_USER_ID=199403748

# Letterboxd (optional) — movies page at /movies uses your username. Defaults to joshuawaldo if not set.
# LETTERBOXD_USERNAME=joshuawaldo

STRAVA_CLIENT_ID=211797
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# --- WHOOP (optional) — GET /api/whoop (training page recovery section)
# App: https://developer.whoop.com — you get Client ID + Secret in the dashboard only.
# OAuth: authorize with offline + read:recovery read:cycles read:sleep read:workout, then exchange ?code= for tokens.
# Put the refresh token here (not the access token). Restart dev server after editing .env.local; set on Vercel + redeploy for production.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
# Must match the app’s “Redirect URL” in WHOOP Developer Dashboard (used to get the refresh token once).
# Copy/paste the SAME string both here and in WHOOP — character for character (http/https, localhost vs 127.0.0.1, port, path, no stray trailing slash unless you registered one).
# WHOOP_REDIRECT_URI=http://127.0.0.1:8765/whoop/callback
# Alternative if you registered this instead:
# WHOOP_REDIRECT_URI=http://localhost:8765/whoop/callback
# Then: npm run whoop:auth  → open printed link → copy ?code= →  npm run whoop:auth -- PASTE_CODE

# --- Contact form (Resend) — portfolio homepage POST /api/contact
# Get API key: https://resend.com/api-keys
# Vercel: after adding/updating, trigger a Production redeploy so /api/contact sees it.
RESEND_API_KEY=re_your_key_here
# Where inbound messages are delivered (defaults to contactjoshuawaldo@gmail.com):
CONTACT_TO_EMAIL=contactjoshuawaldo@gmail.com
# Must be an address Resend allows for your account. Default uses Resend's test sender:
# RESEND_FROM=Portfolio contact <onboarding@resend.dev>
# After you verify your domain at Resend, switch to e.g. RESEND_FROM=You <mail@yourdomain.com>

# --- GitHub contributions (GET /api/github-contributions) — GraphQL via server
# Create a token: https://github.com/settings/tokens — classic PAT; empty scopes OK for public graph.
# Use your own token so counts can match your profile (including private contributions when enabled).
GITHUB_TOKEN=your_github_personal_access_token
