NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=

# Photos — Cloudflare R2 (your old porty setup) or explicit index URL
# If R2_PUBLIC_BASE_URL is set, gallery loads from {R2_PUBLIC_BASE_URL}/gallery/index.json
R2_PUBLIC_BASE_URL=
# Optional override (delete if wrong blob URL — R2 auto-detection will be used instead)
LEGACY_PHOTOS_INDEX_URL=
BLOB_PHOTOS_INDEX_URL=

# WHOOP training sync (recovery, strain, sleep — matches the WHOOP app)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
# Must match WHOOP Developer Dashboard redirect (used when running npm run whoop:auth)
WHOOP_REDIRECT_URI=http://127.0.0.1:8765/whoop/callback
# On Vercel: set this if tokens came from localhost auth (leave WHOOP_REDIRECT_URI unset or same)
WHOOP_REFRESH_REDIRECT_URI=http://127.0.0.1:8765/whoop/callback

# Goodreads + Letterboxd syndication (defaults match old porty site)
GOODREADS_USER_ID=199403748
LETTERBOXD_USERNAME=joshuawaldo
